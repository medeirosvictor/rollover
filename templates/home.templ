package templates

import "github.com/medeirosvictor/rollover/templates/common"

templ Home() {
	@Layout() {
		<section class="flex flex-col justify-center max-w-[720px] h-[100vh]">
			@common.JoinTableInput()
			@common.Button("Join a table", "")
			@common.Button("Create a table", "")
		</section>
	}
}
